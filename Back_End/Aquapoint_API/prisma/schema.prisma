generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model aqua_points {
  id           Int            @id @default(autoincrement())
  point_name   String         @db.Text
  point_type   Int
  point_trust  Int
  local_id     Int
  image        Bytes?         @db.Blob
  latitude     Float
  longitude    Float
  trustlevels  trustlevels    @relation(fields: [point_trust], references: [id], onDelete: Cascade, map: "FK_aqua_points_trustlevels")
  local        local          @relation(fields: [local_id], references: [id], onDelete: Cascade, map: "fk_aqua_points_local")
  type         type           @relation(fields: [point_type], references: [id], onDelete: Cascade, map: "fk_aqua_points_type")
  favorites    favorites[]
  points_state points_state[]
  reports      reports[]
  reviews      reviews[]

  @@index([point_trust], map: "FK_aqua_points_trustlevels")
  @@index([local_id], map: "fk_aqua_points_local")
  @@index([point_type], map: "fk_aqua_points_type")
}

model favorites {
  id          Int         @id @default(autoincrement())
  user_id     Int
  point_id    Int
  date        DateTime    @db.Date
  aqua_points aqua_points @relation(fields: [point_id], references: [id], onDelete: Cascade, map: "fk_favorites_point")
  users       users       @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_favorites_user")

  @@index([point_id], map: "fk_favorites_point")
  @@index([user_id], map: "fk_favorites_user")
}

model local {
  id          Int           @id @default(autoincrement())
  local_name  String        @db.Text
  zone_id     Int
  aqua_points aqua_points[]
  zone        zone          @relation(fields: [zone_id], references: [id], onDelete: Cascade, map: "fk_local_zone")

  @@index([zone_id], map: "fk_local_zone")
}

model points_state {
  id          Int         @id @default(autoincrement())
  point_id    Int
  state_id    Int
  aqua_points aqua_points @relation(fields: [point_id], references: [id], onDelete: Cascade, map: "fk_points_state_point")
  states      states      @relation(fields: [state_id], references: [id], onDelete: Cascade, map: "fk_points_state_state")

  @@index([point_id], map: "fk_points_state_point")
  @@index([state_id], map: "fk_points_state_state")
}

model reports {
  id          Int         @id @default(autoincrement())
  user_id     Int
  comment     String      @db.Text
  point_id    Int
  createdAt   DateTime    @db.Date
  aqua_points aqua_points @relation(fields: [point_id], references: [id], onDelete: Cascade, map: "fk_reports_point")
  users       users       @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_reports_user")

  @@index([point_id], map: "fk_reports_point")
  @@index([user_id], map: "fk_reports_user")
}

model reviews {
  id          Int         @id @default(autoincrement())
  user_id     Int
  rating      Int
  comment     String      @db.Text
  point_id    Int
  createdAt   DateTime    @db.Date
  aqua_points aqua_points @relation(fields: [point_id], references: [id], onDelete: Cascade, map: "fk_reviews_point")
  users       users       @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_reviews_user")

  @@index([point_id], map: "fk_reviews_point")
  @@index([user_id], map: "fk_reviews_user")
}

model states {
  id           Int            @id @default(autoincrement())
  state_name   String         @db.Text
  points_state points_state[]
}

model trustlevels {
  id          Int           @id @default(autoincrement())
  trust_name  String        @db.Text
  aqua_points aqua_points[]
}

model type {
  id          Int           @id @default(autoincrement())
  type_name   String        @db.Text
  aqua_points aqua_points[]
}

model users {
  id             Int         @id @default(autoincrement())
  name           String      @db.Text
  email          String      @db.Text
  passwordHash   String      @db.Text
  profilePicture Bytes?      @db.Blob
  isAdmin        Boolean     @default(false)
  createdAt      DateTime    @default(now()) @db.DateTime(0)
  favorites      favorites[]
  reports        reports[]
  reviews        reviews[]
}

model zone {
  id        Int     @id @default(autoincrement())
  zone_name String  @db.Text
  local     local[]
}
